# ═══════════════════════════════════════════
#  Aether Configuration
#  Your personal AI assistant powered by Claude
# ═══════════════════════════════════════════

# ─── Claude API (Required) ───
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ─── Model Settings ───
AETHER_MODEL=claude-sonnet-4-20250514
AETHER_MAX_TOKENS=4096
AETHER_THINKING=false

# ─── Gateway ───
GATEWAY_PORT=18789
GATEWAY_HOST=127.0.0.1

# ─── Channels (Optional - enable what you need) ───

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=           # comma-separated user IDs

# Discord
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS=            # comma-separated user IDs

# ─── Security ───
AETHER_SECRET=                    # API secret for web gateway
SANDBOX_MODE=true                 # restrict shell execution
ALLOWED_DIRS=                     # comma-separated allowed directories

# ─── Memory ───
MEMORY_ENABLED=true
MEMORY_DB_PATH=./workspace/memory/aether.db

# ─── Logging ───
LOG_LEVEL=info                    # debug, info, warn, error
LOG_FILE=./workspace/logs/aether.log
