  "description": "Your personal AI assistant powered by Claude. Connects everything. The fifth element of AI. ✦",
  "main": "src/index.js",
  "type": "module",
  "bin": {
    "aether": "./bin/aether.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "gateway": "node src/index.js --gateway",
